# ============================================================
# BitcoinCycle Clock — Environment Variables
# Copy this file to .env.local and fill in real values.
# ============================================================

# ------------------------------------------------------------------
# Google AdSense
# Your publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Ad slot IDs — two placements on the home page.
# Leave blank (or omit) to hide ads entirely; the component
# renders null when a slot is missing, preventing 400 errors.
NEXT_PUBLIC_ADSENSE_SLOT_BELOW_FOLD=
NEXT_PUBLIC_ADSENSE_SLOT_BELOW_CHART=
